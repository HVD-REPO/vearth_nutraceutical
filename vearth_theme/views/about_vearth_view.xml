    <!-- ================= HERO ================= -->
    <section class="landing-section">
        <div class="landing-container">
            <video class="landing-content"
       autoplay="autoplay"
       muted="muted"
       loop="loop"
       playsinline="playsinline">
                <source src="/vearth_theme/static/videos/Video_Not_Showing_Correctly.mp4" type="video/mp4"/>
            </video>

            <div class="hero-overlay">
                <div class="container text-center text-white">
                    <h1>About VEARTH Nutraceutical</h1>
                    <p>Science-driven manufacturing powered by nature &amp; innovation</p>
                </div>
            </div>
        </div>
    </section>


    <!-- ================= ABOUT ================= -->
    <section class="about-section scroll-animate">
        <div class="container">
            <div class="row align-items-center g-5">

                <div class="col-lg-6">
                    <h2 class="section-title">Who We Are</h2>

                    <p>
                        VEARTH Nutraceutical is a science-driven nutraceutical manufacturing company
                        based in Ahmedabad, Gujarat. We specialize in clean, research-led formulations
                        crafted with uncompromising quality.
                    </p>

                    <p>
                        At VEARTH, we believe real wellness begins with products that are pure,
                        effective, and transparent.
                    </p>
                </div>

                <div class="col-lg-6">
                    <iframe
                        src="https://www.google.com/maps?q=Ahmedabad,Gujarat&amp;output=embed"
                        width="100%" height="300"
                        style="border:0;border-radius:12px;"
                        loading="lazy">
                    </iframe>
                </div>

            </div>
        </div>
    </section>


    <!-- ================= MISSION ================= -->
    <section class="mission-section scroll-animate">
        <div class="container">
            <div class="row align-items-center g-5">

                <div class="col-lg-6">
                    <img src="/vearth_theme/static/images/about_section_4.png"
                         class="img-fluid mission-img"/>
                </div>

                <div class="col-lg-6">
                    <h2 class="section-title">Our Principles</h2>

                    <p>
                        We empower nutraceutical brands with world-class manufacturing
                        and end-to-end formulation support.
                    </p>

                    <p>
                        Transforming nature into scientifically engineered formulations
                        with quality, transparency, and innovation at the core.
                    </p>
                </div>

            </div>
        </div>
    </section>


    <!-- ================= VISION & MISSION ================= -->
    <section class="vision-section scroll-animate">
        <div class="container">

            <h2 class="section-title text-center">Vision &amp; Mission</h2>

            <div class="row g-4 mt-4">

                <div class="col-lg-6">
                    <div class="vm-card">
                        <div class="vm-icon">
                        <h3>👁️Our Vision</h3>
                    </div>
                        <p>
                            To become India’s most trusted innovation-driven nutraceutical manufacturer,
                            delivering global-standard formulations that empower healthier lives.
                        </p>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="vm-card">
                        <div class="vm-icon"><h3>🎯 Our Mission</h3>

                        </div>
                        <p>
                            To create scientifically validated nutraceutical products that improve
                            health outcomes while setting new standards of trust and purity.
                        </p>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- ================= PROMISE ================= -->
    <section class="promise-section scroll-animate">
        <div class="container text-center">
            <h3>Your Success, Our Expertise</h3>
            <p>
                We help brands — from startups to enterprises — create world-class
                nutraceutical products with unmatched purity, efficacy, and consistency.
            </p>
        </div>
    </section>

                    <section class="vearth-why-ai scroll-animate">

    <!-- glowing background -->
    <div class="ai-bg-glow"></div>

    <div class="container">

        <!-- HEADER -->
        <div class="why-header text-center">
            <h2 class="ai-title">Why Choose VEARTH</h2>
            <p class="ai-subtitle">
                Next-generation nutraceutical manufacturing powered by science,
                transparency and innovation.
            </p>
        </div>

        <div class="ai-layout">

            <!-- LEFT TEXT -->
            <div class="ai-text">
                <p>
                    <strong>Wellness engineered through science.</strong>
                </p>

                <p>
                    VEARTH is built on a simple belief — supplements should be
                    real, effective, and scientifically validated.
                </p>

                <p>
                    We help brands scale with precision manufacturing,
                    premium ingredients and unmatched reliability.
                </p>
            </div>

            <!-- RIGHT CARDS -->
            <div class="ai-cards">

                <div class="ai-card">
                    <i class="fa fa-eye"></i>
                    <span>Transparent Manufacturing</span>
                </div>

                <div class="ai-card">
                    <i class="fa fa-leaf"></i>
                    <span>Ethical &amp;  Clean Sourcing</span>
                </div>

                <div class="ai-card">
                    <i class="fa fa-truck"></i>
                    <span>Reliable Delivery Timelines</span>
                </div>

                <div class="ai-card">
                    <i class="fa fa-globe"></i>
                    <span>Premium Global Ingredients</span>
                </div>

                <div class="ai-card">
                    <i class="fa fa-flask"></i>
                    <span>Scientific Formulations</span>
                </div>

                <div class="ai-card">
                    <i class="fa fa-comments"></i>
                    <span>Customer First Approach</span>
                </div>

            </div>

        </div>

    </div>

</section>
